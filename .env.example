# Copy this to .env.local and fill in your values

# ─── JWT (server-side — NEVER prefix with NEXT_PUBLIC) ───────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# ─── Admin credentials (server-side only) ────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-admin-password

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/motomart"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=MotoMart
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=/api

# ─── AI / Groq (free tier — server-side only, NEVER prefix with NEXT_PUBLIC) ──
# Get your free key at https://console.groq.com
GROQ_API_KEY=gsk_your-key-here
