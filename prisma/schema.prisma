generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Users (phone / email OTP login) ──────────────────────────────────────────
model User {
  id         String   @id @default(uuid())
  name       String   @db.VarChar(100)
  identifier String   @unique @db.VarChar(255) // phone or email
  role       String   @default("user") @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  sessions   RefreshToken[]

  @@map("users")
}

// ── Admins (username + bcrypt password) ──────────────────────────────────────
model Admin {
  id           String   @id @default(uuid())
  name         String   @db.VarChar(100)
  identifier   String   @unique @db.VarChar(100) // username
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         String   @default("admin") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sessions     RefreshToken[]

  @@map("admins")
}

// ── OTP store (phone/email → OTP, TTL, attempts) ──────────────────────────────
model Otp {
  identifier String   @id @db.VarChar(255) // phone or email
  otp        String   @db.VarChar(6)
  expiresAt  DateTime @map("expires_at")
  attempts   Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("otps")
}

// ── Parts catalog ─────────────────────────────────────────────────────────────
model Part {
  id             String   @id @default(uuid())
  sku            String   @unique @db.VarChar(50)
  name           String   @db.VarChar(200)
  description    String   @default("") @db.Text
  category       String   @db.VarChar(50)
  brand          String   @db.VarChar(50)
  price          Decimal  @db.Decimal(10, 2)
  mrp            Decimal  @db.Decimal(10, 2)
  stock          Int      @default(0)
  minStock       Int      @default(10) @map("min_stock")
  images         String[] @default([])
  compatibleBikes String[] @default([]) @map("compatible_bikes")
  rating         Decimal  @default(0) @db.Decimal(3, 2)
  reviewCount    Int      @default(0) @map("review_count")
  isFeatured     Boolean  @default(false) @map("is_featured")
  isSale         Boolean  @default(false) @map("is_sale")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([brand])
  @@index([isFeatured])
  @@map("parts")
}

// ── Brands (managed by admin, shown on storefront) ───────────────────────────
model Brand {
  id        String   @id @default(uuid())
  name      String   @unique @db.VarChar(100)
  initials  String   @db.VarChar(10)
  color     String   @db.VarChar(100) // Tailwind border+hover classes
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@index([sortOrder])
  @@map("brands")
}

// ── Admin notifications (stock alerts, etc.) ──────────────────────────────────
model Notification {
  id        String   @id @default(uuid())
  type      String   @db.VarChar(50)   // "low_stock" | "out_of_stock"
  title     String   @db.VarChar(200)
  message   String   @db.Text
  partId    String?  @map("part_id") @db.VarChar(36)
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ── Refresh tokens (allows revocation & rotation) ────────────────────────────
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique @db.VarChar(512)
  sub       String   @db.VarChar(36) // user or admin id
  role      String   @db.VarChar(20) // "user" | "admin"
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  // Optional FK to User (null when role=admin)
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String?  @map("user_id") @db.VarChar(36)

  // Optional FK to Admin (null when role=user)
  admin     Admin?   @relation(fields: [adminId], references: [id], onDelete: Cascade)
  adminId   String?  @map("admin_id") @db.VarChar(36)

  @@map("refresh_tokens")
}
